//@version=6
indicator("NGX News & Volume Spike Detector", overlay=true)

// ─── Inputs ───────────────────────────────────────────────────────────────────
volLookback   = input.int(20,  title="Volume SMA Period",    minval=5, maxval=100)
volMultiplier = input.float(2.0, title="Volume Spike Threshold (×avg)", minval=1.1, step=0.1)
gapThreshold  = input.float(2.0, title="Gap Open Threshold (%)",        minval=0.5, step=0.5)
bigGapPct     = input.float(5.0, title="Big Gap Threshold (%)",         minval=1.0, step=0.5)

showVolSpike  = input.bool(true,  title="Show Volume Spike Markers")
showGaps      = input.bool(true,  title="Show Gap Open Markers")
showBigGaps   = input.bool(true,  title="Highlight Big Gaps (bgcolor)")

// ─── Volume Analysis ──────────────────────────────────────────────────────────
avgVol    = ta.sma(volume, volLookback)
volRatio  = avgVol > 0 ? volume / avgVol : 0.0
isVolSpike = volRatio >= volMultiplier

// ─── Gap Analysis ─────────────────────────────────────────────────────────────
gapPct    = close[1] > 0 ? (open - close[1]) / close[1] * 100 : 0.0
isGapUp   = gapPct >=  gapThreshold
isGapDown = gapPct <= -gapThreshold
isBigGap  = math.abs(gapPct) >= bigGapPct

// Sustained gap: closed above/below open throughout the bar
sustainedGapUp   = isGapUp   and close > close[1]
sustainedGapDown = isGapDown and close < close[1]

// ─── Combined News Signal ─────────────────────────────────────────────────────
// News-driven move: volume spike AND a meaningful gap — strongest signal
newsSignalUp   = isVolSpike and isGapUp
newsSignalDown = isVolSpike and isGapDown

// Volume-only surge (intraday news without gap)
intraVolUp   = isVolSpike and not isGapUp   and close > open
intraVolDown = isVolSpike and not isGapDown and close < open

// ─── Plots ────────────────────────────────────────────────────────────────────
// Volume ratio ribbon at bottom of bars
plot(volRatio, title="Volume Ratio", display=display.none)

// Gap open markers
plotshape(showGaps and isGapUp   and not newsSignalUp,
     title="Gap Up",  style=shape.triangleup,
     location=location.belowbar, color=color.new(color.teal, 40),
     size=size.small, text="GAP↑", textcolor=color.teal)

plotshape(showGaps and isGapDown and not newsSignalDown,
     title="Gap Down", style=shape.triangledown,
     location=location.abovebar, color=color.new(color.orange, 40),
     size=size.small, text="GAP↓", textcolor=color.orange)

// News (gap + volume) markers — larger, more prominent
plotshape(showVolSpike and newsSignalUp,
     title="News Spike Up",  style=shape.labelup,
     location=location.belowbar, color=color.new(color.green, 0),
     size=size.normal, text="📰↑", textcolor=color.white)

plotshape(showVolSpike and newsSignalDown,
     title="News Spike Down", style=shape.labeldown,
     location=location.abovebar, color=color.new(color.red, 0),
     size=size.normal, text="📰↓", textcolor=color.white)

// Volume-only spikes (no gap)
plotshape(showVolSpike and intraVolUp,
     title="Volume Surge Up",   style=shape.circle,
     location=location.belowbar, color=color.new(color.green, 50),
     size=size.tiny)

plotshape(showVolSpike and intraVolDown,
     title="Volume Surge Down", style=shape.circle,
     location=location.abovebar, color=color.new(color.red, 50),
     size=size.tiny)

// Big gap background highlight
bgcolor(showBigGaps and isBigGap ?
     (gapPct > 0 ? color.new(color.green, 90) : color.new(color.red, 90)) : na,
     title="Big Gap Background")

// ─── Alerts ───────────────────────────────────────────────────────────────────
alertcondition(newsSignalUp,   title="NGX News Gap + Volume Up",   message="News-driven gap up with volume surge detected")
alertcondition(newsSignalDown, title="NGX News Gap + Volume Down",  message="News-driven gap down with volume surge detected")
alertcondition(isVolSpike,     title="NGX Volume Spike",            message="Volume spike: " + str.tostring(volRatio, "#.#") + "× average")
alertcondition(isBigGap,       title="NGX Big Gap Open",            message="Big gap open: " + str.tostring(gapPct, "+#.##;-#.##") + "%")
